<resources>

    <!--
        Base application theme, dependent on API level. This theme is replaced
        by AppBaseTheme from res/values-vXX/styles.xml on newer devices.
    -->
    <style name="AppBaseTheme" parent="android:Theme.Light">
        <!--
            Theme customizations available in newer API levels can go in
            res/values-vXX/styles.xml, while customizations related to
            backward-compatibility can go here.
        -->
    </style>

    <!-- Application theme. -->
    <style name="AppTheme" parent="AppBaseTheme">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>
    
    <style name="CardInfoTitle" >
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#0096d0</item>
    </style>
    
    <style name="CardInfoText" >
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#000000</item>
    </style>
    
    <style name="CardInfoRed" >
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#ff0000</item>
    </style>
    
    <style name="StatusLabel" >
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#666666</item>
    </style>
    <style name="CheckBoxText" >
        <item name="android:textSize">20sp</item>
        <item name="android:minHeight">0sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="BtnStyle" >
        <item name="android:textSize">20sp</item>
        <item name="android:minHeight">0sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center</item>
    </style>
    <style name="SpinnerText">
        <item name="android:minHeight">32dip</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textAppearance">@android:style/TextAppearance.Medium</item>
        <item name="android:showDividers">middle</item>
        <item name="android:dividerHeight">1dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:paddingStart">@dimen/padding_start</item>
        <item name="android:paddingEnd">@dimen/padding_end</item>
    </style>
    <style name="WarpLinearLayoutDefault">
		<item name="grivate">left</item>
		<item name="horizontal_Space">20dp</item>
		<item name="vertical_Space">20dp</item>
		<item name="isFull">false</item>
	</style>
</resources>
