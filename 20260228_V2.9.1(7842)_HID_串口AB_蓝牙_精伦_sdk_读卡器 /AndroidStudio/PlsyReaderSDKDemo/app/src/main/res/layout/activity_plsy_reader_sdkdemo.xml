<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.routon.plsy.reader.sdk.demo.view.IDCardView
        android:id="@+id/viewIDCardView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
    />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dip"
        android:layout_margin="1dip"
        android:background="@android:color/black" />

    <TextView
        android:id="@+id/textViewStatus"
        style="@style/StatusLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#c0c3c7"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:text="@string/readcard_hint"
     />

    <com.routon.plsy.reader.sdk.demo.view.WrapLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dip"
		android:paddingStart="@dimen/padding_start"
		android:paddingEnd="@dimen/padding_end"
		app:grivate="left"
		app:isFull="false"
		app:horizontal_Space="10dp"
		app:vertical_Space="1dp"
		>
		<CheckBox
            android:id="@+id/checkbox_readBCard"
            android:text="@string/readb"
			style="@style/CheckBoxText"
			android:checked="true"
             />
        <CheckBox
            android:id="@+id/checkbox_readACard"
            android:text="@string/reada"
			style="@style/CheckBoxText"
             />
        <CheckBox
            android:id="@+id/checkbox_readCardCid"
            android:text="@string/readCardCid"
			style="@style/CheckBoxText"
             />

        <CheckBox
            android:id="@+id/checkbox_readfp"
            android:text="@string/readfp"
			style="@style/CheckBoxText"
             />

        <CheckBox
            android:id="@+id/checkbox_dualChannel"
            style="@style/CheckBoxText"
            android:text="@string/dualChannel" />
        
        <CheckBox
            android:id="@+id/checkbox_useCache"
            style="@style/CheckBoxText"
            android:text="@string/useCache"
            android:checked="true" />

	</com.routon.plsy.reader.sdk.demo.view.WrapLinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
		android:paddingStart="@dimen/padding_start"
		android:paddingEnd="@dimen/padding_end"
          >
		
        <Spinner
            android:id="@+id/spinner_select_device"          
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:prompt="@string/spinnerTitle"
            android:spinnerMode="dialog"
            android:minHeight="0dp"           
         />
        <Button
            android:id="@+id/btnBtSearch"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_horizontal|center_vertical"
            android:background="@drawable/btn_search_selector"
			android:paddingStart="@dimen/padding_start"
            android:paddingEnd="@dimen/padding_end"
            android:visibility="gone" />
        <EditText
            android:id="@+id/etSerDevname"
			android:layout_marginLeft="@dimen/padding_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/edit"
            android:inputType="text"
            android:textSize="12sp"	
            android:gravity="center"
            android:minHeight="0dp" 
            android:hint="请输入设备名"
            android:text="/dev/ttyS3"
            android:visibility="gone" 
        />
    </LinearLayout>
	
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
		android:paddingStart="@dimen/padding_start"
		android:paddingEnd="@dimen/padding_end"
        >

        <Button
            android:id="@+id/buttonStart"
            android:text="@string/start_readcard"
            style="@style/BtnStyle"
             />

        <Button
            android:id="@+id/buttonStop"
            android:text="@string/stop_readcard"
            style="@style/BtnStyle" />

		<Button
			android:id="@+id/buttonStartSlave"
			android:text="@string/start_slave"
			style="@style/BtnStyle" />
		<Button
			android:id="@+id/buttonStopSlave"
			android:text="@string/stop_slave"
			style="@style/BtnStyle" />
        <Button
            android:id="@+id/buttonBack"
            android:text="@string/back"
            style="@style/BtnStyle" />
        <Button
            android:id="@+id/buttonTestLag"
            android:text="@string/testLag"
            style="@style/BtnStyle" />
        
        <TextView
            android:id="@+id/tvLag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/NetReaderText"
            android:layout_gravity="center"
			android:paddingStart="@dimen/padding_start"
			android:paddingEnd="@dimen/padding_end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dip"
        android:background="@android:color/black"
		android:paddingStart="1dp"
		android:paddingEnd="1dp"
         >

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/singleReadButtons"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dip"
		android:paddingStart="@dimen/padding_start"
		android:paddingEnd="@dimen/padding_end"
         >

        <Button
            android:id="@+id/buttonOnceRead"
            android:text="USB单次读卡"
            style="@style/BtnStyle"
			android:paddingStart="@dimen/padding_start"
			android:paddingEnd="@dimen/padding_end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dip"
        android:background="@android:color/black"
        android:paddingLeft="1dip"
        android:paddingRight="1dip" >

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black" />
    </LinearLayout>
	<HorizontalScrollView 
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
		android:paddingStart="@dimen/padding_start"
		android:paddingEnd="@dimen/padding_end"
       >
    
	    <LinearLayout        
	        android:id="@+id/USBManual"
	        android:layout_width="wrap_content"
	        android:layout_height="wrap_content"
	        android:orientation="vertical" >
	 
	        <TextView
	            android:layout_width="match_parent"
	            android:layout_height="wrap_content"
	            android:text="USB手动测试读卡"
				android:paddingStart="@dimen/padding_start"
				android:paddingEnd="@dimen/padding_end"/>
	
	        <LinearLayout
	            android:layout_width="match_parent"
	            android:layout_height="wrap_content"
	            android:orientation="horizontal" >
	
	            <Button
	                android:id="@+id/buttonOpen"
	                android:text="打开读卡器"
	                style="@style/BtnStyle"
					android:paddingStart="@dimen/padding_start"
					android:paddingEnd="@dimen/padding_end"/>
	            <EditText 
	                android:id="@+id/etProgCode"
	                android:hint="请输入8位项目码"
	                android:maxLength="8"
	                android:layout_width="100dp"
	                android:layout_height="wrap_content"
	                android:background="@drawable/edit"
	                android:inputType="text"
	                android:textSize="12sp"	
	                android:minHeight="0dp"
	                android:layout_gravity="center"             
	            />
	            <Button
	                android:id="@+id/buttonChkProgCode"
	                android:text="验证项目码"	                
	                style="@style/BtnStyle" />
	        </LinearLayout>
	
	        <LinearLayout
	            android:layout_width="match_parent"
	            android:layout_height="wrap_content"
	            android:orientation="horizontal" >
				<Button
	                android:id="@+id/buttonFind"
	                android:text="找卡"
	                style="@style/BtnStyle"
					android:paddingStart="@dimen/padding_start"
					android:paddingEnd="@dimen/padding_end"/>
	
	            <Button
	                android:id="@+id/buttonSelect"
	                android:text="选卡"
	                style="@style/BtnStyle"/>
	            <Button
	                android:id="@+id/buttonReadBaseMsg"
	                android:text="读卡"
	                style="@style/BtnStyle" />
	
	            <Button
	                android:id="@+id/buttonReadNewAppMsg"
	                android:text="读追加信息"
	                style="@style/BtnStyle" />
	            
	            <Button
	                android:id="@+id/buttonGetSamId"
	                android:text="SAMID"
	                style="@style/BtnStyle" />
	            
	            <Button
	                android:id="@+id/buttonTransmit"
	                android:text="透传测试"
	                style="@style/BtnStyle" />
	            
	            <Button
	                android:id="@+id/buttonSIMTest"
	                android:text="SIM卡测试"
	                style="@style/BtnStyle" />
	
	            <Button
	                android:id="@+id/buttonClose"
	                android:text="关闭读卡器"
	                style="@style/BtnStyle" />
	        </LinearLayout>
	    </LinearLayout>
	</HorizontalScrollView>
	
	
	<LinearLayout        
	        android:id="@+id/layoutSerialManual"
	        android:layout_width="wrap_content"
	        android:layout_height="wrap_content"
	        android:orientation="vertical" >
	 
	        <TextView
	            android:layout_width="match_parent"
	            android:layout_height="wrap_content"
	            android:text="串口手动测试"
				android:paddingStart="@dimen/padding_start"
				android:paddingEnd="@dimen/padding_end"/>
	
	        <LinearLayout
	            android:layout_width="match_parent"
	            android:layout_height="wrap_content"
	            android:orientation="horizontal" >

	            <EditText 
	                android:id="@+id/etWriteData"
	                android:hint="请输入写入数据"
	                android:maxLength="224"
	                android:layout_width="150dp"
	                android:layout_height="wrap_content"
	                android:background="@drawable/edit"
	                android:inputType="text"
	                android:textSize="12sp"	
	                android:minHeight="0dp"
	                android:layout_gravity="center"
	                android:paddingLeft="@dimen/padding_start"         
	                android:layout_marginStart="@dimen/padding_start"    
	            />
	            
	            <EditText 
	                android:id="@+id/etSectorNo"
	                android:hint="索引(0-27)"
	                android:maxLength="2"
	                android:layout_width="80dp"
	                android:layout_height="wrap_content"
	                android:background="@drawable/edit"
	                android:inputType="number"
	                android:textSize="12sp"	
	                android:minHeight="0dp"
	                android:layout_gravity="center"           
	                android:layout_marginLeft="@dimen/padding_start"  
	            />
	            
	            <EditText 
	                android:id="@+id/etSectorCnt"
	                android:hint="数量(1-28)"
	                android:maxLength="2"
	                android:layout_width="80dp"
	                android:layout_height="wrap_content"
	                android:background="@drawable/edit"
	                android:inputType="number"
	                android:textSize="12sp"	
	                android:minHeight="0dp"
	                android:layout_gravity="center"    
	                android:layout_marginLeft="@dimen/padding_start"           
	            />
	            

	        </LinearLayout>
	
	        <LinearLayout
	            android:layout_width="match_parent"
	            android:layout_height="wrap_content"
	            android:orientation="horizontal" >
	            <Button
	                android:id="@+id/buttonOpenSerial"
	                android:text="打开读卡器"
	                style="@style/BtnStyle"
					android:paddingStart="@dimen/padding_start"
					android:paddingEnd="@dimen/padding_end"/>
	
	            
	            <Button
	                android:id="@+id/buttonReadCardID"
	                android:text="读卡ID"
	                style="@style/BtnStyle"
	                android:enabled="false" />
	            <Button
	                android:id="@+id/buttonWriteData"
	                android:text="写数据"
	                 android:enabled="false"
	                style="@style/BtnStyle"/>
	            <Button
	                android:id="@+id/buttonReadData"
	                android:text="读数据"
	                 android:enabled="false"
	                style="@style/BtnStyle" />

	            <Button
	                android:id="@+id/buttonCloseSerial"
	                android:text="关闭读卡器"
	                android:enabled="false"
	                style="@style/BtnStyle" />
	        </LinearLayout>
	    </LinearLayout>
	
	<LinearLayout        
	        android:id="@+id/NetworkReader"
	        android:layout_width="wrap_content"
	        android:layout_height="wrap_content"
	        android:orientation="vertical"
	        android:visibility="invisible" >
	 
		        <LinearLayout
		            android:layout_width="match_parent"
		            android:layout_height="wrap_content"
		            android:orientation="horizontal">
		
		            <Button
		                android:id="@+id/buttonOpenUSReader"
		                android:text="打开读卡器"
		                style="@style/BtnStyle"/>
		            
		           <Button
			            android:id="@+id/buttonOnceReadUS"
			            android:text="单次读卡"
			            style="@style/BtnStyle"
			            android:enabled="false"/>
		            
		            <Button
		                android:id="@+id/buttonCloseReader"
		                android:text="关闭读卡器"
		                style="@style/BtnStyle"
		                android:enabled="false"/>
		            
		            <Button
		                android:id="@+id/buttonTestLatency"
		                android:text="网络延迟测试"
		                style="@style/BtnStyle"
		                android:enabled="true"/>
		           
		        </LinearLayout>
		        
		        <LinearLayout
			        android:layout_width="match_parent"
			        android:layout_height="1dip"
			        android:background="@android:color/black"
			        android:paddingLeft="1dip"
			        android:paddingRight="1dip" >
			
			        <View
			            android:layout_width="match_parent"
			            android:layout_height="match_parent"
			            android:background="@android:color/black" />
			    </LinearLayout>
			    
		        <TextView
		            android:layout_width="match_parent"
		            android:layout_height="wrap_content"
		            android:text="网络读卡器参数"
					android:paddingStart="@dimen/padding_start"
					android:paddingEnd="@dimen/padding_end"/>
		        
		        <LinearLayout
		            android:layout_width="match_parent"
		            android:layout_height="wrap_content"
		            android:orientation="horizontal" >
		            
		            <TextView
		                android:id="@+id/tvModuleStatus"
			            android:layout_width="wrap_content"
			            android:layout_height="wrap_content"
			            android:text="Cat1模块："
			            style="@style/NetReaderText"
						android:paddingStart="@dimen/padding_start"
						android:paddingEnd="@dimen/padding_end"/>
		            
		            <TextView
		                android:id="@+id/tvConnStatus"
			            android:layout_width="wrap_content"
			            android:layout_height="wrap_content"
			            android:text="连接状态："
			            style="@style/NetReaderText"
						android:paddingStart="@dimen/padding_start"
						android:paddingEnd="@dimen/padding_end"/>
		            
		            <TextView
		                android:id="@+id/tvConnType"
			            android:layout_width="wrap_content"
			            android:layout_height="wrap_content"
			            android:text="连接类型："
			            style="@style/NetReaderText"
						android:paddingStart="@dimen/padding_start"
						android:paddingEnd="@dimen/padding_end"/>
		            
		            <!-- <TextView
		                android:id="@+id/tvConnLatency"
			            android:layout_width="wrap_content"
			            android:layout_height="wrap_content"
			            android:text="网络延迟："
			            style="@style/NetReaderText"
						android:paddingStart="@dimen/padding_start"
						android:paddingEnd="@dimen/padding_end"/> -->

		        </LinearLayout>
		        
		        <LinearLayout
		            android:layout_width="match_parent"
		            android:layout_height="wrap_content"
		            android:orientation="horizontal" >
		            
		        	 <TextView
		                android:id="@+id/tvConnLatency"
			            android:layout_width="wrap_content"
			            android:layout_height="wrap_content"
			            android:text="网络延迟："
			            style="@style/NetReaderText"
						android:paddingStart="@dimen/padding_start"
						android:paddingEnd="@dimen/padding_end"/>
		        	
		        </LinearLayout>
		        
		         <LinearLayout
		            android:layout_width="match_parent"
		            android:layout_height="wrap_content"
		            android:orientation="horizontal" >
		        	
		        	<TextView
			            android:layout_width="wrap_content"
			            android:layout_height="wrap_content"
			            android:text="平台参数："
			            style="@style/NetReaderText"
			            android:gravity="center_horizontal"
						android:paddingStart="@dimen/padding_start"/>
		        
		            <EditText 
		                android:id="@+id/etPlatform"
		                android:hint="平台地址和端口号"
		                android:maxLength="40"
		                android:layout_width="160dp"
		                android:layout_height="wrap_content"
		                android:background="@drawable/edit"
		                android:inputType="text"
		                android:textSize="12sp"	
		                android:minHeight="0dp"
		                android:layout_gravity="center"
		                android:gravity="center"
		                android:enabled="false"/>
		            
		            <Spinner
			            android:id="@+id/spinner_conn_type"          
			            android:layout_width="wrap_content"
			            android:layout_height="wrap_content"
			            android:prompt="@string/spinnerTitleConntype"
			            android:spinnerMode="dialog"
			            android:minHeight="0dp"
			            android:textSize="12sp"	
		         	/>
		        </LinearLayout>
	        </LinearLayout>
	
    <LinearLayout
        
        android:layout_width="match_parent"
        android:layout_height="1dip"
        android:background="@android:color/black"
        android:paddingLeft="1dip"
        android:paddingRight="1dip" >

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
		android:paddingStart="@dimen/padding_start"
		android:paddingEnd="@dimen/padding_end"
    >
        <TextView
            android:id="@+id/txtLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceSmall"
			android:paddingStart="@dimen/padding_start"
			android:paddingEnd="@dimen/padding_end"/>
    </ScrollView>

</LinearLayout>